# oh-my-images (AI image generation) — optional API keys
#
# Copy this file to .env (gitignored) or export the variables in your shell
# before running the AI image generation step in oh-my-slides.

# Nanobanana / Google Imagen 3 (default provider)
GOOGLE_API_KEY=

# OpenAI (gpt-image-1, DALL-E 3)
OPENAI_API_KEY=

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=

# Optional: pick a non-default provider
# Options: nanobanana | openai | stability
# OH_MY_IMAGES_PROVIDER=nanobanana
